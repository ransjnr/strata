{
  "name": "@ransjnr/strata",
  "version": "0.3.0",
  "description": "Declarative, type-safe, parallel request pipeline — a better alternative to middleware",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.mjs",
      "require": "./dist/adapters/express.js"
    },
    "./groq": {
      "types": "./dist/providers/groq.d.ts",
      "import": "./dist/providers/groq.mjs",
      "require": "./dist/providers/groq.js"
    }
  },
  "bin": {
    "strata": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/adapters/express.ts src/providers/groq.ts src/cli.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/adapters/express.ts src/providers/groq.ts src/cli.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "middleware",
    "strata",
    "pipeline",
    "nextjs",
    "typescript",
    "request",
    "web",
    "handler",
    "parallel",
    "type-safe",
    "zod",
    "cloudflare-workers",
    "hono",
    "agent",
    "ai",
    "llm",
    "groq",
    "tools"
  ],
  "author": "ransjnr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ransjnr/strata.git"
  },
  "homepage": "https://github.com/ransjnr/strata#readme",
  "bugs": {
    "url": "https://github.com/ransjnr/strata/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "express": "^5.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "groq-sdk": ">=0.7.0",
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "groq-sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "git-filter-repo": "^0.0.30"
  }
}
